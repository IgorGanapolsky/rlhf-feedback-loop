{
  "presets": {
    "conservative": {
      "description": "High-reliability production deploys — favors proven patterns",
      "alpha_prior": 10,
      "beta_prior": 2,
      "decay_rate": 0.95,
      "exploration_bonus": 0.05,
      "min_samples_before_exploit": 20,
      "use_cases": ["production-deploy", "hotfix", "security-patch"]
    },
    "exploratory": {
      "description": "R&D and prototyping — high exploration, tolerates failure",
      "alpha_prior": 1,
      "beta_prior": 1,
      "decay_rate": 0.80,
      "exploration_bonus": 0.30,
      "min_samples_before_exploit": 5,
      "use_cases": ["prototyping", "spike", "research", "new-framework"]
    },
    "balanced": {
      "description": "Day-to-day development — moderate exploration with guardrails",
      "alpha_prior": 3,
      "beta_prior": 2,
      "decay_rate": 0.90,
      "exploration_bonus": 0.15,
      "min_samples_before_exploit": 10,
      "use_cases": ["feature-dev", "bugfix", "refactor", "code-review"]
    },
    "strict": {
      "description": "Compliance-critical workflows — minimal exploration, maximum reliability",
      "alpha_prior": 20,
      "beta_prior": 1,
      "decay_rate": 0.98,
      "exploration_bonus": 0.02,
      "min_samples_before_exploit": 50,
      "use_cases": ["audit", "compliance", "data-migration", "release"]
    }
  },
  "version": "1.0.0",
  "compatible_with": "mcp-memory-gateway >=1.0.0"
}
