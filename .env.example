# Required for API auth (unless RLHF_ALLOW_INSECURE=true in local isolated testing)
RLHF_API_KEY=change-me

# Optional hosted billing configuration
# STRIPE_PUBLISHABLE_KEY=pk_live_change_me
# STRIPE_SECRET_KEY=sk_live_change_me
# STRIPE_PRODUCT_ID=prod_change_me
# STRIPE_PRICE_ID=price_change_me
# STRIPE_WEBHOOK_SECRET=whsec_change_me

# Optional local paths
# RLHF_FEEDBACK_DIR=.claude/memory/feedback
# RLHF_CONTEXTFS_DIR=.claude/memory/feedback/contextfs

# Optional strictness toggles
# RLHF_ALLOW_INSECURE=false
# RLHF_ALLOW_EXTERNAL_PATHS=false
# RLHF_SEMANTIC_CACHE_ENABLED=true
# RLHF_SEMANTIC_CACHE_THRESHOLD=0.7
# RLHF_SEMANTIC_CACHE_TTL_SECONDS=86400

# Monthly budget cap in USD for paid operations (PaperBanana, etc.)
# RLHF_MONTHLY_BUDGET_USD=10

# Optional LLM gateway routing (for paid hosted calls only)
# LLM_GATEWAY_BASE_URL=
# LLM_GATEWAY_API_KEY=
# TETRATE_API_KEY=

# Perplexity Max API (for marketing engine — npm run marketing)
# PERPLEXITY_API_KEY=pplx-...

# Grok / xAI API
# XAI_API_KEY=xai-...

# X.com / Twitter API (for automated posting — node scripts/post-to-x.js)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
