# Core runtime
# Required for API auth (unless RLHF_ALLOW_INSECURE=true in local isolated testing)
RLHF_API_KEY=change-me
# RLHF_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z
# RLHF_PUBLIC_APP_ORIGIN=https://rlhf-feedback-loop-production.up.railway.app
# RLHF_BILLING_API_BASE_URL=https://rlhf-feedback-loop-production.up.railway.app
# RLHF_FEEDBACK_DIR=/data/feedback
# RLHF_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# RLHF_GOOGLE_SITE_VERIFICATION=google-site-verification-token

# Billing
# STRIPE_PUBLISHABLE_KEY=pk_live_change_me
# STRIPE_SECRET_KEY=sk_live_change_me
# STRIPE_SECRET_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z
# STRIPE_PRODUCT_ID=prod_change_me
# STRIPE_PRICE_ID=price_change_me
# STRIPE_ONE_TIME_PRICE_ID=price_change_me
# STRIPE_WEBHOOK_SECRET=whsec_change_me
# STRIPE_WEBHOOK_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
# GITHUB_MARKETPLACE_WEBHOOK_SECRET=github_webhook_secret
# GITHUB_MARKETPLACE_WEBHOOK_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
# RLHF_GITHUB_MARKETPLACE_PLAN_PRICES_JSON={"1":{"amountCents":4900,"currency":"USD"}}

# Railway deploy
# RAILWAY_TOKEN=railway_token
# RAILWAY_TOKEN_ROTATED_AT=2026-03-12T00:00:00.000Z
# RAILWAY_PROJECT_ID=project_id
# RAILWAY_ENVIRONMENT_ID=environment_id
# RAILWAY_SERVICE=rlhf-feedback-loop
# RAILWAY_HEALTHCHECK_URL=https://rlhf-feedback-loop-production.up.railway.app/health

# Optional local paths
# RLHF_FEEDBACK_DIR=.claude/memory/feedback
# RLHF_CONTEXTFS_DIR=.claude/memory/feedback/contextfs
# RLHF_REVENUE_LEDGER_PATH=.claude/memory/feedback/revenue-events.jsonl

# Optional strictness toggles
# RLHF_ALLOW_INSECURE=false
# RLHF_ALLOW_EXTERNAL_PATHS=false
# RLHF_SEMANTIC_CACHE_ENABLED=true
# RLHF_SEMANTIC_CACHE_THRESHOLD=0.7
# RLHF_SEMANTIC_CACHE_TTL_SECONDS=86400

# Monthly budget cap in USD for paid operations (PaperBanana, etc.)
# RLHF_MONTHLY_BUDGET_USD=10

# Optional LLM gateway routing (for paid hosted calls only)
# LLM_GATEWAY_BASE_URL=
# LLM_GATEWAY_API_KEY=
# TETRATE_API_KEY=

# ADK / GTM
# GEMINI_API_KEY=
# GEMINI_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z

# Perplexity Max API (for marketing engine — npm run marketing)
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z

# Grok / xAI API
# XAI_API_KEY=xai-...

# X.com / Twitter API (for automated posting — node scripts/post-to-x.js)
# X_API_KEY=
# X_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z
# X_API_SECRET=
# X_API_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_ROTATED_AT=2026-03-12T00:00:00.000Z
# X_ACCESS_TOKEN_SECRET=
# X_ACCESS_TOKEN_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
