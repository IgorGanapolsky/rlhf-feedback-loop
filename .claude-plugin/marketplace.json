{
  "name": "mcp-memory-gateway",
  "version": "0.7.1",
  "plugins": [
    {
      "name": "mcp-memory-gateway",
      "description": "Claude Desktop project memory and guardrails for coding agents. Stop repeated mistakes with recall, pre-action checks, and proof-backed runs.",
      "type": "mcp",
      "source": {
        "type": "npm",
        "package": "mcp-memory-gateway",
        "command": "npx",
        "args": ["-y", "mcp-memory-gateway", "serve"]
      },
      "metadata": {
        "author": "Igor Ganapolsky",
        "homepage": "https://github.com/IgorGanapolsky/mcp-memory-gateway",
        "license": "MIT",
        "keywords": [
          "claude-desktop",
          "desktop-extension",
          "workflow-hardening",
          "coding-agents",
          "project-memory",
          "guardrails",
          "pre-action-checks",
          "proof-backed-runs",
          "mcp",
          "memory"
        ],
        "category": "developer-tools"
      }
    }
  ]
}
